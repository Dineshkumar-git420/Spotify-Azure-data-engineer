{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-spotify-data"
		},
		"DBspotify_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'DBspotify'"
		},
		"datalakespotify_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'datalakespotify'"
		},
		"DBspotify_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "kdspotifyserver.database.windows.net"
		},
		"DBspotify_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Dineshspotifydb"
		},
		"DBspotify_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "dineshadmin"
		},
		"datalakespotify_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://kdspotifydata.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-spotify-data_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"DBspotify_password": {
						"value": "[parameters('DBspotify_password')]"
					},
					"datalakespotify_accountKey": {
						"value": "[parameters('datalakespotify_accountKey')]"
					},
					"DBspotify_properties_typeProperties_server": {
						"value": "[parameters('DBspotify_properties_typeProperties_server')]"
					},
					"DBspotify_properties_typeProperties_database": {
						"value": "[parameters('DBspotify_properties_typeProperties_database')]"
					},
					"DBspotify_properties_typeProperties_userName": {
						"value": "[parameters('DBspotify_properties_typeProperties_userName')]"
					},
					"datalakespotify_properties_typeProperties_url": {
						"value": "[parameters('datalakespotify_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}